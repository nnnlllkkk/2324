    {
      "name": "GET - получить все продукты",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Pre-request\r",
              "// (Место для кода, который выполнится до отправки запроса)\r",
              "\r",
              "// Post-response\r",
              "pm.test(\"Статус должен быть 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Content-Type = application/json\", function () {\r",
              "    pm.response.to.have.header(\"Content-Type\", \"application/json; charset=utf-8\");\r",
              "});\r",
              "\r",
              "pm.test(\"Cache-Control содержит max-age, если присутствует\", function () {\r",
              "    let cacheHeader = pm.response.headers.get(\"Cache-Control\");\r",
              "    if (cacheHeader) pm.expect(cacheHeader).to.include(\"max-age\");\r",
              "});\r",
              "\r",
              "pm.test(\"В ответе есть поле products - массив\", function () {\r",
              "    let jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property(\"products\").that.is.an(\"array\").that.is.not.empty;\r",
              "});\r",
              "\r",
              "// Authorization\r",
              "// (Место для кода или переменных, связанных с авторизацией)\r",
              "\r",
              "// Cookies\r",
              "// (Место для кода или переменных, связанных с куки)"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Cache-Control",
            "value": "max-age=180",
            "type": "text"
          },
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
